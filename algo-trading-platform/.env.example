NODE_ENV=development
TZ=Asia/Kolkata

# --- Datastores ---
MONGO_URI=mongodb://localhost:27017/algotrade
REDIS_URI=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Broker credential encryption (AES-256-GCM, 32 bytes base64-encoded) ---
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BROKER_ENC_KEY=ep/Es8UWTWBCbUv9ed4Z8ek6tDix0iarer0qMZ0chtA=

# --- Per-broker app keys (only what is needed at app-level — user creds come at connect time) ---
ZERODHA_APP_ID=
ANGELONE_API_KEY=
UPSTOX_API_KEY=
DHAN_CLIENT_ID=
FYERS_APP_ID=

# --- Service ports ---
PORT_API=4000
PORT_MARKET_DATA=4001
PORT_EXECUTION=4002
PORT_STRATEGY=4003
PORT_SIGNAL=4004

# --- Default broker for dev (mock|zerodha|angelone|upstox|dhan|fyers) ---
DEFAULT_BROKER=mock

# --- Observability ---
LOG_LEVEL=info
