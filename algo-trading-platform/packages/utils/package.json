{
  "name": "@algo/utils",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./config": { "types": "./dist/config.d.ts", "default": "./dist/config.js" },
    "./logger": { "types": "./dist/logger.d.ts", "default": "./dist/logger.js" },
    "./time": { "types": "./dist/time.d.ts", "default": "./dist/time.js" },
    "./crypto": { "types": "./dist/crypto.d.ts", "default": "./dist/crypto.js" },
    "./errors": { "types": "./dist/errors.d.ts", "default": "./dist/errors.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
